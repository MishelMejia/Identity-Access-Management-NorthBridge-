## Step 2 — Create Delegation Groups OU

New-ADOrganizationalUnit -Name "Delegation_Groups" -Path "OU=5.NB_Groups,DC=northbridge,DC=local"  

Image: images/02-delegation-groups-ou.png

---

## Step 3 — Create Delegation Groups

$path = "OU=Delegation_Groups,OU=5.NB_Groups,DC=northbridge,DC=local"  

New-ADGroup -Name "DLG_Helpdesk_Reset_Users" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_Helpdesk_Modify_ContactAttributes" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_Helpdesk_Read_LoginAttributes" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_Helpdesk_Join_Computers" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_Helpdesk_Move_Users" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_HR_Modify_Users" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_HR_Disable_Users" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_HR_CreateDelete_Users" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_HR_Move_DisabledUsers" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_Managers_Read_Departments" -GroupScope Global -GroupCategory Security -Path $path  
New-ADGroup -Name "DLG_Managers_Read_GroupMembership" -GroupScope Global -GroupCategory Security -Path $path  

Image: images/03-delegation-groups-created.png

